#!/usr/bin/env bash
# macOS: Globally update or check LLM-related npm CLIs
# 包含：
#   - @google/gemini-cli
#   - @openai/codex
#   - @anthropic-ai/claude-code
#   - opencode-ai
# 功能：
#   - 自动检测当前 vs 最新版本
#   - 若版本一致则跳过更新
#   - 支持 --check 模式（仅检查不安装）
#   - 自动判断是否需 sudo
#   - 支持 PACKAGES / NPM_REGISTRY 环境变量覆盖

set -euo pipefail

# ------------------ 默认包列表 ------------------
DEFAULT_PACKAGES=(
  "@google/gemini-cli"
  "@openai/codex"
  "@anthropic-ai/claude-code"
  "@fission-ai/openspec"
  "opencode-ai"
)

# ------------------ 参数解析 ------------------
MODE="update"
if [[ "${1:-}" == "--check" ]]; then
  MODE="check"
fi

# ------------------ 环境变量覆盖 ------------------
if [[ -n "${PACKAGES:-}" ]]; then
  # shellcheck disable=SC2206
  PKGS=(${PACKAGES})
else
  PKGS=("${DEFAULT_PACKAGES[@]}")
fi

if [[ -n "${NPM_REGISTRY:-}" ]]; then
  npm config set registry "${NPM_REGISTRY}"
fi

# ------------------ 基础检查 ------------------
need() { command -v "$1" >/dev/null 2>&1 || { echo "❌ 缺少命令：$1"; exit 1; }; }
need node
need npm

USING_NVM="no"
if [[ -n "${NVM_DIR:-}" ]] || command -v nvm >/dev/null 2>&1 || [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  USING_NVM="yes"
fi

PREFIX="$(npm config get prefix 2>/dev/null || echo "")"
SUDO_CMD=""
if [[ -n "$PREFIX" ]]; then
  if [[ ! -w "$PREFIX" ]] && [[ "$USING_NVM" != "yes" ]]; then
    SUDO_CMD="sudo"
  fi
fi

# ------------------ 函数定义 ------------------
npm_version() { npm view "$1" version 2>/dev/null || echo ""; }

installed_version() {
  local name="$1"
  local json
  json="$(npm ls -g --depth=0 --json "$name" 2>/dev/null || true)"
  NAME="$name" node -e '
    const fs=require("fs");
    let s=""; process.stdin.on("data",d=>s+=d).on("end",()=>{
      try{
        const j=JSON.parse(s||"{}");
        const deps=j.dependencies||{};
        const n=process.env.NAME;
        if (deps[n] && deps[n].version) {
          console.log(deps[n].version);
        }
      }catch(e){}
    });
  ' <<<"$json"
}

cli_name_guess() {
  case "$1" in
    "@google/gemini-cli") echo "gemini" ;;
    "@openai/codex") echo "codex" ;;
    "@anthropic-ai/claude-code") echo "claude-code" ;;
    "opencode-ai") echo "opencode" ;;
    *) echo "" ;;
  esac
}

update_pkg() {
  local pkg="$1"
  local current latest
  current="$(installed_version "$pkg" || true)"
  latest="$(npm_version "$pkg" || true)"

  echo "————————————————————————————————————————————————"
  echo "▶ 包：$pkg"
  [[ -n "$current" ]] && echo "  - 当前：$current" || echo "  - 当前：未安装"
  [[ -n "$latest"  ]] && echo "  - 最新：$latest"

  # --- 仅检查模式 ---
  if [[ "$MODE" == "check" ]]; then
    if [[ -z "$latest" ]]; then
      echo "  - ⚠️ 无法获取最新版本"
    elif [[ -z "$current" ]]; then
      echo "  - 📦 尚未安装"
    elif [[ "$current" == "$latest" ]]; then
      echo "  - ✅ 已是最新版"
    else
      echo "  - ⬆️ 可更新：$current → $latest"
    fi
    return 0
  fi

  # --- 更新模式 ---
  if [[ -n "$current" && -n "$latest" && "$current" == "$latest" ]]; then
    echo "  - ✅ 已是最新版，跳过更新"
    return 0
  fi

  echo "  - 正在更新 → latest..."
  if ${SUDO_CMD:-} npm install -g "${pkg}@latest"; then
    :
  else
    echo "⚠️ 更新失败。若为权限问题，请尝试：sudo npm install -g \"${pkg}@latest\""
    return 1
  fi

  local after
  after="$(installed_version "$pkg" || true)"
  echo "  - 更新后版本：${after:-未知}"

  local bin
  bin="$(cli_name_guess "$pkg")"
  if [[ -n "$bin" ]] && command -v "$bin" >/dev/null 2>&1; then
    echo -n "  - CLI 版本："
    "$bin" --version || true
  fi
}

# ------------------ 主逻辑 ------------------
echo "Node: $(node -v)"
echo "npm : $(npm -v)"
echo "npm prefix: ${PREFIX:-unknown}  (nvm: $USING_NVM)"
[[ -n "${NPM_REGISTRY:-}" ]] && echo "registry: $NPM_REGISTRY"
echo "包列表：${PKGS[*]}"
echo "模式：$MODE"
echo "————————————————————————————————————————————————"

fail=0
for p in "${PKGS[@]}"; do
  if ! update_pkg "$p"; then
    fail=$((fail+1))
  fi
done

echo "————————————————————————————————————————————————"
if [[ "$MODE" == "check" ]]; then
  echo "🔍 检查完成"
else
  if [[ $fail -eq 0 ]]; then
    echo "✅ 全部更新完成"
  else
    echo "⚠️ 有 $fail 个包更新失败，请查看上方提示"
  fi
fi
